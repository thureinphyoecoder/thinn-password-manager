{
  "name": "thinn-password-manager",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electronmon . --no-sandbox",
    "start": "electron . --no-sandbox",
    "test": "node --test",
    "ci:check": "node --test",
    "dist:linux": "npx electron-builder --linux deb --publish never",
    "dist:win": "npx electron-builder --win nsis --publish never"
  },
  "keywords": [],
  "author": {
    "name": "Thu Rein Phyoe",
    "email": "thureinphyoecoder@users.noreply.github.com"
  },
  "license": "ISC",
  "description": "Local-only encrypted password manager built with Electron.",
  "build": {
    "appId": "com.thinn.passwordmanager",
    "productName": "Thinn Password Manager",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "icon": "icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electronmon": "^2.0.4"
  }
}
